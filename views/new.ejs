<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create New Post</title>
     <link rel="stylesheet" href="/style.css" />
</head>
<body>
     <div class="page-wrapper">
        <a href="/posts" class="back-btn">← Back to Posts</a>

        <div class="detail-card">
            <span class="badge">Create New Post</span>

            <form action="/posts" method="post">
                <div class="form-group">
                    <label>👤 Username</label>
                    <input type="text" name="username" placeholder="Enter your username" class="form-input" />
                </div>

                <div class="form-group">
                    <label>✏️ Your Post</label>
                    <textarea name="content" rows="6" placeholder="What's on your mind?" class="edit-textarea"></textarea>
                </div>

                <button class="save-btn">🚀 Submit Post</button>
            </form>
        </div>
    </div>


